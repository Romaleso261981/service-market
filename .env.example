# ========== Firebase Client (браузер) ==========
# З Firebase Console → Project settings → Your apps → SDK setup and configuration.
# Потрібно для клієнтських фіч (Auth, тощо). Для лише Firestore через API достатньо серверних змінних нижче.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=service-market-28547.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=service-market-28547
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=service-market-28547.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=897250857760
NEXT_PUBLIC_FIREBASE_APP_ID=1:897250857760:web:dfeaee2a7f1e27beb7bd45

# ========== Firebase Admin (сервер, Firestore для товарів) ==========
# Значення з JSON ключа (service account): project_id, client_email, private_key.
# Файл *-firebase-adminsdk-*.json не комітити в репозиторій.
FIREBASE_PROJECT_ID=service-market-28547
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@service-market-28547.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
